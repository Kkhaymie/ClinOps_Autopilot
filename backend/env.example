# Copy this file to .env and fill in real values. Never commit the real .env.

# ── DATABASE (Supabase) ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── AI CLASSIFICATION ───────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_key_here
GROQ_API_KEY=your_groq_key_here
# OLLAMA_HOST=http://localhost:11434   # only needed for local dev fallback

# ── WHATSAPP CLOUD API (Meta) ───────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=clinops_webhook_verify_2026
META_APP_SECRET=your_meta_app_secret

# ── AFRICA'S TALKING (SMS) ───────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_SENDER_ID=ClinOps

# ── TELEGRAM ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── EMAIL (SMTP, for email channel + coordinator alerts) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
COORDINATOR_EMAIL=coordinator@example.com
COORDINATOR_WHATSAPP_NUMBER=234XXXXXXXXXX

# ── MEDIA STORAGE (Cloudinary) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ── APP SETTINGS ────────────────────────────────────────────────────
ENVIRONMENT=development
